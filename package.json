{
  "name": "localpulse-mcp",
  "version": "0.1.0",
  "description": "MCP server for value-first cold outreach to local service businesses",
  "type": "module",
  "bin": {
    "localpulse-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/vitest/vitest.mjs run",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mcp", "outreach", "local-business", "cold-email"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=20"
  }
}
